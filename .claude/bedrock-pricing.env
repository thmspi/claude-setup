BEDROCK_DEFAULT_OUTPUT_PER_MTOK=15.00

# Claude family-specific rates
BEDROCK_HAIKU_INPUT_PER_MTOK=0.25
BEDROCK_HAIKU_OUTPUT_PER_MTOK=1.25

